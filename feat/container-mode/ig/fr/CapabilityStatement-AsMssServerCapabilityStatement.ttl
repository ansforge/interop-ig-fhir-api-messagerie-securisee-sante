         ] ;
         fhir:type [ fhir:v "token" ] ;
         fhir:documentation [ fhir:v "Identifiant national de structure (`idnatstruct`). Utilisé comme critère de conditional PATCH." ]
       ] )
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/5.0/StructureDefinition/extension-CapabilityStatement.rest.resource.conditionalPatch"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:boolean ;
           fhir:v true
         ]
       ] ) ;
